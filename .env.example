# ============================================
# Slip Verification API - Environment Variables
# ============================================

# --------------------------------------------
# Server Configuration
# --------------------------------------------
PORT=8080
ENV=development

# --------------------------------------------
# Database Configuration
# --------------------------------------------
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database?sslmode=disable
DB_URL=postgresql://slipverify:password@localhost:5432/slipsure?sslmode=disable

# Redis for caching and job queues (optional for now)
REDIS_URL=redis://localhost:6379


# LINE Messaging API Configuration
LINE_MESSAGING_CHANNEL_ID=2010059227
LINE_MESSAGING_CHANNEL_SECRET=779f5b269729cc7cd7ba9c1c844dec0f
LINE_MESSAGING_ACCESS_TOKEN=BXI/exLnViN5EJKTC3spc7B/myPXl6KYYILaIYB4lWXqqcnmZ/dLfZq6O70WdtTgFuWTG22Mmi+cmOoKwNK26UoA1ylP6HeJ1Qp+/Uy8eQH4TAkp7JkKZzFXT1of1t+fbZ9aRx+twbz9YDcDFct1JgdB04t89/1O/w1cDnyilFU=

# LINE Login Configuration (Backend OAuth verification)
LINE_LOGIN_CHANNEL_ID=2010058902
LINE_LOGIN_CHANNEL_SECRET=625dc1a32f83fcd30b0e83aee33f954d
LINE_LOGIN_CALLBACK_URL=http://localhost:3000/auth/line/callback

# DigitalOcean Spaces (S3-compatible Storage)
SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
SPACES_REGION=sgp1
SPACES_BUCKET=slipsure
SPACES_ACCESS_KEY=your_spaces_access_key_here
SPACES_SECRET_KEY=your_spaces_secret_key_here

# KBank API Configuration
K_API_KEY=your_kbank_api_key_here
# KBank API Base URL
KBANK_API_URL=https://api.kbank.com/v1
KBANK_MOCK_MODE=true

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=3600

# AWS SES (Email Service) - Queued for future implementation
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=ap-southeast-1
SES_CONFIGURATION_SET=your-ses-configuration-set

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Application Settings
SLIP_RETENTION_DAYS=90
MAX_SLIP_SIZE_MB=10
SUPPORTED_IMAGE_FORMATS=jpg,jpeg,png,webp

# ============================================
# Frontend Configuration
# ============================================

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8080/v1
NEXT_PUBLIC_API_TIMEOUT=30000

# LINE Login (Frontend OAuth)
NEXT_PUBLIC_LINE_LOGIN_CHANNEL_ID=your_line_login_channel_id_here
NEXT_PUBLIC_LINE_LOGIN_CALLBACK_URL=http://localhost:3000/auth/line/callback

# Application Settings
NEXT_PUBLIC_APP_NAME=SlipSure
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_LINE_LOGIN=true

