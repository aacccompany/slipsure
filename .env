# --- BACKEND CONFIGURATION ---
PROJECT_NAME="FlowSlip API"
USE_MOCK=True

# Security (Change SECRET_KEY in production!)
SECRET_KEY=your-super-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
# Default is SQLite. For PostgreSQL: postgresql+asyncpg://user:pass@localhost/db
DATABASE_URL=sqlite+aiosqlite:///./flowslip.db

# KBank API Credentials
KBANK_CLIENT_ID=your_client_id_here
KBANK_CLIENT_SECRET=your_client_secret_here
KBANK_API_URL=https://openapi-sandbox.kasikornbank.com

# Line OA Configuration
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_access_token


# --- FRONTEND CONFIGURATION ---
# The URL of your backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Set to 'true' to use frontend-side mock data in Dashboard
NEXT_PUBLIC_USE_MOCK=false
